PORT=3001

# Supabase — values for local dev come from `supabase start` output.
# For production, copy from the Supabase project's API settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL the frontend uses to reach this backend. Used to build the
# mock-provider `authUrl`.
PUBLIC_BACKEND_URL=http://localhost:3001

# Public URL of the frontend. Used as the base for the mock-provider
# authorize 302 redirect to /sell/callback.
FRONTEND_URL=http://localhost:3000
